# Platform bring-up config — Nucleus serve-loop MVP (v0.0)
# --------------------------------------------------------------------------
# Copy to `.env` to override. run_all.sh sources this file if present and falls
# back to these exact defaults for anything unset, so it also runs with no .env.
#
#   cp .env.example .env
#   bash run_all.sh
# --------------------------------------------------------------------------

# Model backend switch (the one knob that makes it real).
#   mock  = canned, streamed answer. No GPU. Runs on any box. DEFAULT for v0.0.
#   vllm  = OpenAI-compatible client to a real vLLM server serving Qwen3-VL-32B.
# Flipping this to vllm AND running services/inference/serve_vllm.sh on the
# a3mega node (TP=8, one node) is what turns the mock loop into the real one.
# Only `mock` is expected to run without the GPU node.
MODEL_BACKEND=mock

# Base world model (BWM) served by inference. Also the C6 resolve model_id.
MODEL_ID=Qwen/Qwen3-VL-32B-Instruct

# Bind host for all local services (loopback for dev).
HOST=127.0.0.1

# Ports (localhost dev) — pinned in handoff/engineering.md "MVP build conventions".
STORAGE_PORT=8083     # storage: /sessions (C4) + model directory (C6)
INFERENCE_PORT=8010   # inference: /infer (C9 stream), resolves C6, writes C4
OUTPUT_PORT=8082      # output: C9 relay + markdown render
INPUT_PORT=8081       # input: chat surface + QueryBuilder (produces C3)  <- the URL users open
VLLM_PORT=8000        # real vLLM server (only used when MODEL_BACKEND=vllm)

# Inter-service URLs. Defaults are derived from HOST + the ports above; set them
# explicitly only if you split services across hosts.
STORAGE_URL=http://127.0.0.1:8083
INFERENCE_URL=http://127.0.0.1:8010
OUTPUT_URL=http://127.0.0.1:8082
INPUT_URL=http://127.0.0.1:8081
VLLM_URL=http://127.0.0.1:8000

# Python interpreter used to build the shared venv. Target is 3.11 (any 3.11+
# works). Leave unset to auto-detect python3.11 -> python3.12 -> python3.
# PYTHON_BIN=python3.11

# Seconds to wait for each service's /health before giving up.
HEALTH_TIMEOUT=60

# --------------------------------------------------------------------------
# HTTPS / remote reach (DEFERRED — not needed for local mock).
# A phone or external tester reaches this box over HTTPS via a cloudflared
# tunnel pointed at the input port, e.g.:
#     cloudflared tunnel --url http://localhost:8081
# That is later platform work (see README "mock -> real" + worklog). Local
# mock bring-up needs none of it.
# --------------------------------------------------------------------------
