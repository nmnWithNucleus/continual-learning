# Platform bring-up config — Nucleus LEARN-loop capture MVP (M0)
# --------------------------------------------------------------------------
# Copy to `learn.env` to override. run_learn.sh sources this file if present
# and falls back to these exact defaults for anything unset, so it also runs
# with no learn.env at all.
#
#   cp learn.env.example learn.env
#   bash run_learn.sh
#
# This is the LEARN loop (capture spine): recording -> data-processing ->
# storage /context. It is SEPARATE from the serve loop (run_all.sh + .env);
# the two never share this file.
# --------------------------------------------------------------------------

# ASR backend switch (the one knob that makes ASR real).
#   mock            = canned transcript + one/two fake segments spanning the
#                     chunk. No GPU, no torch. Runs on any box. DEFAULT for M0.
#   faster_whisper  = real ASR (lazy-imported only when selected). Needs the
#                     faster-whisper stack; CPU-capable but slow.
# Only `mock` is expected to run in this workflow.
ASR_BACKEND=mock

# Bind host for all local services (loopback for dev).
HOST=127.0.0.1

# Ports (localhost dev) — pinned in README-learn.md + STACK conventions.
STORAGE_PORT=8083     # storage: /raw (blob write/read) + /context (C2 write/read)  [EXISTING service, extended]
DP_PORT=8085          # data-processing: POST /ingest (C1 receiver) -> ASR -> C2    [NEW]
RECORDING_PORT=8084   # recording: capturer + POST /capture/run                     [NEW]

# Inter-service URLs. Defaults derive from HOST + the ports above; set them
# explicitly only if you split services across hosts.
#   data-processing needs STORAGE_URL (pull blob, POST /context/records).
#   recording       needs STORAGE_URL (PUT /raw/blobs) + DP_URL (POST /ingest).
STORAGE_URL=http://127.0.0.1:8083
DP_URL=http://127.0.0.1:8085
RECORDING_URL=http://127.0.0.1:8084

# --------------------------------------------------------------------------
# Smoke defaults (used by `run_learn.sh --smoke`).
# The M0 capturer reads a CONTINUOUS audio source; there is no mic on this box,
# so the source is a local WAV file. run_learn.sh generates a synthetic sample
# WAV (make_sample_wav.py, stdlib only) at SAMPLE_WAV if it does not exist.
# --------------------------------------------------------------------------
SAMPLE_WAV=            # absolute path to the source WAV; empty = deploy/sample/sample_audio.wav
SAMPLE_SECONDS=12      # length of the generated sample WAV (12s / 5s chunks = 3 chunks: seq 0,1,2)
CHUNK_SECONDS=5        # chunk duration the capturer carves the stream into

# Python interpreter used to build the shared venv (target 3.11; any 3.11+
# works — the on-node envs are 3.12). Leave unset to auto-detect
# python3.11 -> python3.12 -> python3.
# PYTHON_BIN=python3.11

# Seconds to wait for each service's /health before giving up.
HEALTH_TIMEOUT=90
