{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nucleus.ai/contracts/c3_userprompt.v0.json",
  "title": "C3 UserPrompt v0 (serve-loop MVP, text-only)",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "version", "user_id", "session_id", "turn_id", "created_at", "messages", "client_capabilities", "template_version"],
  "properties": {
    "contract": { "const": "C3" },
    "version": { "const": "0" },
    "user_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "turn_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "description": "RFC3339 / ISO-8601 UTC timestamp" },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "text"],
        "properties": {
          "role": { "enum": ["user", "system"] },
          "text": { "type": "string" }
        }
      },
      "description": "v0: a single user message; inference prepends the system prompt."
    },
    "client_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "modalities", "can_render_markdown"],
      "properties": {
        "surface": { "enum": ["computer", "extension", "mobile", "wearable"], "description": "v0.0 exercises 'computer'." },
        "modalities": { "type": "array", "items": { "enum": ["text", "speech", "image", "video"] }, "description": "v0.0 = ['text']." },
        "can_render_markdown": { "type": "boolean" }
      }
    },
    "template_version": { "type": "string", "description": "QueryBuilder chat-template version stamped into every prompt." }
  }
}
